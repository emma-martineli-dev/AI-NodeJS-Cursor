generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ScenarioRun {
  id        String   @id @default(uuid())
  name      String
  status    String
  metric    Float?
  log       String?
  error     String?
  createdAt DateTime @default(now())
}
