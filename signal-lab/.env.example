# Copy to .env and fill in values
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal_lab

# Backend (used by Prisma inside the container)
DATABASE_URL=postgresql://signal:signal@postgres:5432/signal_lab

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional
PORT=3001
NODE_ENV=development
