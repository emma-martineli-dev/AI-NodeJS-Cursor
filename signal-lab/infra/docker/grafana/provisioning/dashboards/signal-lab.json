{
  "title": "Signal Lab",
  "uid": "signal-lab-main",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Runs per minute — by type",
      "description": "Rate of scenario runs, split by type. Spike = load; flatline = idle.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(scenario_runs_total[1m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Error rate — failed / total",
      "description": "Ratio of failed runs. Should be 0 for all types except system_error and chaos_monkey.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(scenario_runs_total{status=\"failed\"}[1m])) / sum by (type) (rate(scenario_runs_total[1m]))",
          "legendFormat": "{{type}} error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Duration p50 / p95 (ms)",
      "description": "Scenario execution time. slow_query should show 500-2000ms; others <50ms.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (type, le) (rate(scenario_duration_ms_bucket[5m])))",
          "legendFormat": "p50 {{type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (type, le) (rate(scenario_duration_ms_bucket[5m])))",
          "legendFormat": "p95 {{type}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Total runs — completed vs failed",
      "description": "Cumulative counter. Use to verify scenarios are being recorded.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(scenario_runs_total{status=\"completed\"})",
          "legendFormat": "Completed",
          "refId": "A"
        },
        {
          "expr": "sum(scenario_runs_total{status=\"failed\"})",
          "legendFormat": "Failed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "vertical", "textMode": "value_and_name", "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "chaos_monkey — success rate",
      "description": "chaos_monkey fails ~50% of the time by design. This panel shows the actual rate.",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(scenario_runs_total{type=\"chaos_monkey\",status=\"completed\"}) / sum(scenario_runs_total{type=\"chaos_monkey\"})",
          "legendFormat": "Success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "All scenario logs",
      "description": "Structured JSON logs from the backend. Filter by type using the search bar above.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=\"signal-lab-backend\"} | json | event=~\"scenario_run.*\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 7,
      "title": "Failed runs — errors only",
      "description": "Only scenario_run_failed events. Each line has type, runId, error, durationMs.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=\"signal-lab-backend\"} | json | event=\"scenario_run_failed\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
