{
  "title": "Signal Lab",
  "uid": "signal-lab-main",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Scenario Runs by Type (counter over time)",
      "description": "Rate of scenario runs per minute, split by type. PRD 002 F8.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(scenario_runs_total[1m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (counter filtered by status=error/failed)",
      "description": "Ratio of failed+error runs to total. PRD 002 F8.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(scenario_runs_total{status=~\"failed|error\"}[1m])) / sum by (type) (rate(scenario_runs_total[1m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latency Distribution — p50 / p95 (seconds)",
      "description": "scenario_run_duration_seconds histogram. slow_request should show 2-5s. PRD 002 F8.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (type, le) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (type, le) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{type}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Requests Total",
      "description": "http_requests_total by method, path, status_code. PRD 002 F5.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (path, status_code) (rate(http_requests_total[1m]))",
          "legendFormat": "{{path}} {{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "Run totals — completed vs failed",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(scenario_runs_total{status=\"completed\"})", "legendFormat": "Completed", "refId": "A" },
        { "expr": "sum(scenario_runs_total{status=\"failed\"})", "legendFormat": "Failed", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 6,
      "title": "chaos_monkey success rate",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(scenario_runs_total{type=\"chaos_monkey\",status=\"completed\"}) / sum(scenario_runs_total{type=\"chaos_monkey\"})",
          "legendFormat": "Success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "teapot signal",
      "description": "Should show 42 when teapot scenario is run.",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(scenario_runs_total{type=\"teapot\"})", "legendFormat": "🫖 teapot runs", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "purple", "mode": "fixed" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 8,
      "title": "Loki — All scenario logs (filterable by scenarioType)",
      "description": "Query: {app=\"signal-lab\"} | json | event=~\"scenario_run.*\". Filter by scenarioType label. PRD 002 F8 optional.",
      "type": "logs",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"signal-lab\"} | json | event=~\"scenario_run.*\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 9,
      "title": "Loki — Failed runs only",
      "description": "Query: {app=\"signal-lab\"} | json | event=\"scenario_run_failed\"",
      "type": "logs",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{app=\"signal-lab\"} | json | event=\"scenario_run_failed\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
