---
description: All DB access must go through PrismaService — no raw drivers, no raw SQL
globs: ["signal-lab/apps/api/src/**/*.ts"]
alwaysApply: true
---

# Prisma Usage

## Always use PrismaService via DI
```ts
// ✅ DO
@Injectable()
export class ScenariosService {
  constructor(private readonly prisma: PrismaService) {}

  findAll() {
    return this.prisma.scenarioRun.findMany({
      orderBy: { createdAt: 'desc' },
      take: 50,
    });
  }
}

// ❌ DON'T — instantiate PrismaClient directly
import { PrismaClient } from '@prisma/client';
const prisma = new PrismaClient();          // bypasses DI, creates extra connections
```

## No raw SQL — ever
```ts
// ❌ DON'T — all of these are forbidden
this.prisma.$queryRaw`SELECT * FROM "ScenarioRun"`;
this.prisma.$executeRaw`DELETE FROM "ScenarioRun"`;
this.prisma.$queryRawUnsafe(userInput);     // SQL injection risk
```

## No raw DB drivers in application code
```ts
// ❌ DON'T — import raw drivers
import { Client } from 'pg';
import { createPool } from 'mysql2';
import Database from 'better-sqlite3';
```

## Use generated Prisma types — never duplicate them
```ts
// ✅ DO
import type { ScenarioRun } from '@prisma/client';

async findOne(id: string): Promise<ScenarioRun> { ... }

// ❌ DON'T — manual interface that mirrors the model
interface ScenarioRun {
  id: string;
  name: string;
  status: string;   // now you have two sources of truth
}
```

## Schema changes go through Prisma — never manual DDL
```
# ✅ DO
1. Edit prisma/schema.prisma
2. npx prisma db push          (dev, no migration file)
   OR
   npx prisma migrate dev      (dev, with migration history)
3. npx prisma generate

# ❌ DON'T
psql -c "ALTER TABLE ..."      # schema drift — Prisma won't know
```
